# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored — NEVER commit real keys.

# ── News MCP (EventRegistry) — Layer 1 live source ──────────────────
# Credentials from https://eventregistry.org
EVENTREGISTRY_API_KEY=

# ── Embeddings ──
# EMBED_BACKEND=transformers → free local sentence-transformers (all-MiniLM-L6-v2, no key).
#   NOTE: recalibrate riskPolicy.embeddingGate thresholds (lower scale than simpleEmbed).
# VOYAGE_API_KEY → Voyage API (needs key). Default (both empty) = simpleEmbed.
EMBED_BACKEND=
VOYAGE_API_KEY=

# ── Stage 2/3 via LOCAL model (FREE). Priority: ollama > anthropic > stub. ──
# Run free:  ollama pull gemma3:4b && ollama serve
OLLAMA_MODEL=
OLLAMA_URL=http://localhost:11434/api/generate
# HYBRID (best of both): Stage 2 free local, Stage 3 high-quality Claude.
#   OLLAMA_MODEL=gemma3:4b  +  ANTHROPIC_API_KEY=...  +  STAGE3_PROVIDER=anthropic
STAGE2_PROVIDER=
STAGE3_PROVIDER=

# ── Stage 2 / Stage 3 reasoning (Anthropic Claude — used if OLLAMA_MODEL unset) ──
ANTHROPIC_API_KEY=

# ── Apertus — Swiss sovereign LLM (data-sovereignty story). Use via STAGE3_PROVIDER=apertus ──
APERTUS_API_KEY=
APERTUS_BASE_URL=https://api.publicai.co/v1
APERTUS_MODEL=swiss-ai/apertus-70b-instruct

# ── Multi-model synthetic data generators (add as keys become available) ──
OPENAI_API_KEY=
GEMINI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# ── Server ──────────────────────────────────────────────────────────
PORT=8787
# Comma-separated origins allowed to call this backend (the frontend URL)
CORS_ORIGIN=http://localhost:5173
