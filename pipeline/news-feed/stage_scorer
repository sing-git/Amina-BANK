def load_kyc(company_id):
    with KYC_FILE.open() as f:
        db = json.load(f)
    return next((c for c in db if c["company_id"] == company_id), None)


def load_articles():
    with ARTICLES_FILE.open() as f:
        data = json.load(f)
    return data.get("articles", [])


def source_category(source_feed: str) -> str:
    """Map feed URL to a category tag shown in the UI."""
    feed = (source_feed or "").lower()
    if any(x in feed for x in ["sanction", "ofac", "opensanctions"]):
        return "sanctions"
    if any(x in feed for x in ["gleif", "companies house", "opencorporates", "zefix", "registry"]):
        return "registry"
    if any(x in feed for x in ["crunchbase", "wellfound", "pitchbook", "funding", "startup"]):
        return "funding"
    if any(x in feed for x in ["whois", "domain", "securitytrails", "wayback"]):
        return "domain"
    return "news"


def write_audit(entry: dict):
    with AUDIT_LOG.open("a", encoding="utf-8") as f:
        f.write(json.dumps(entry) + "\n")


# ---------------------------------------------------------------------------
# 2. ENTITY FUZZY MATCH  — rapidfuzz vs KYC legal name + domain
# ---------------------------------------------------------------------------

def entity_fuzzy_score(article: dict, kyc: dict) -> float:
    """Score how strongly the article's NER entities match the KYC company."""
    targets = [
        kyc["legal_name"],
        kyc.get("domain", "").replace(".", " "),
    ]
    companies = article.get("companies", [])
    if not companies:
        return 0.0

    best = 0.0
    for entity in companies:
        name = entity.get("name", "")
        for target in targets:
            ratio = fuzz.token_set_ratio(name, target) / 100.0
            best = max(best, ratio)
    return round(best, 4)


# ---------------------------------------------------------------------------
# 3. SANCTIONS EXACT LOOKUP  — OpenSanctions free API
# ---------------------------------------------------------------------------

def sanctions_lookup(legal_name: str, key_personnel: dict) -> tuple[bool, list[str]]:
    """
    Returns (is_sanctioned, matched_names).
    Checks company name + all key personnel.
    Free OpenSanctions API — no key required for basic queries.
    Falls back gracefully on network error.
    """
    names_to_check = [legal_name] + list(key_personnel.values())
    matched = []

    for name in names_to_check:
        try:
            resp = requests.post(
                OPENSANCTIONS_API,
                json={"queries": {"q": {"schema": "Thing", "properties": {"name": [name]}}}},
                timeout=8,
            )
            if resp.status_code == 200:
                data = resp.json()
                results = data.get("responses", {}).get("q", {}).get("results", [])
                if results and results[0].get("score", 0) > 0.7:
                    matched.append(name)
        except requests.RequestException:
            pass  # network failure — don't block scoring

    return bool(matched), matched


# ---------------------------------------------------------------------------
# 4. EMBEDDING COSINE SIMILARITY  — sentence-transformers (local, free)
# ---------------------------------------------------------------------------

_embedding_model = None


def get_embedding_model():
    global _embedding_model
    if _embedding_model is None:
        from sentence_transformers import SentenceTransformer
        print("Loading embedding model (all-MiniLM-L6-v2) ...")
        _embedding_model = SentenceTransformer("all-MiniLM-L6-v2")
    return _embedding_model


def embedding_drift_score(article_text: str, baseline_business_model: str, use_embeddings: bool) -> float:
    """
    Cosine DISTANCE between article text and KYC baseline business model.
    High distance = content is far from what was expected = KYC drift signal.
    Returns a score 0.0-1.0 where higher = more drift.
    """
    if not use_embeddings or not article_text or not baseline_business_model:
        return 0.0
    try:
        import numpy as np
        model = get_embedding_model()
        vecs = model.encode([article_text[:512], baseline_business_model], normalize_embeddings=True)
        cosine_sim = float(np.dot(vecs[0], vecs[1]))
        # Convert similarity → drift: high similarity = low drift
        drift = round((1.0 - cosine_sim) / 2.0, 4)  # map [-1,1] → [0,1]
        return drift
    except Exception:
        return 0.0


# ---------------------------------------------------------------------------
# 5. RULE-BASED DELTA  — CEO name, jurisdiction, legal form
# ---------------------------------------------------------------------------

def rule_based_delta(text: str, title: str, kyc: dict) -> tuple[bool, list[str]]:
    """
    Check if KYC-specific fields appear in anomalous context.
    Returns (delta_detected, list_of_reasons).
    """
    content = (title + " " + text).lower()
    reasons = []

    # CEO / key personnel name mentioned with negative verbs
    negative_verbs = ["arrested", "charged", "resign", "fired", "fled", "convicted", "indicted"]
    for role, name in kyc.get("key_personnel", {}).items():
        name_lower = name.lower()
        if name_lower in content:
            for verb in negative_verbs:
                if verb in content:
                    reasons.append(f"{role} '{name}' mentioned with '{verb}'")
                    break

    # Legal name change signals
    legal_name = kyc["legal_name"].lower()
    if "formerly known as" in content or "renamed" in content or "rebranded" in content:
        if any(part in content for part in legal_name.split()[:2]):
            reasons.append("Entity rename signal near company name")

    # Domain in article (check for domain change signals)
    domain = kyc.get("domain", "")
    if domain and domain.lower() in content:
        if any(w in content for w in ["redirect", "suspended", "seized", "taken down", "new domain"]):
            reasons.append(f"Domain '{domain}' mentioned with change signal")

    # Jurisdiction / legal form change
    jurisdiction_signals = ["moved to", "relocated to", "redomiciled", "now based in",
                            "offshore", "cayman", "bvi", "malta", "seychelles"]
    for signal in jurisdiction_signals:
        if signal in content:
            reasons.append(f"Jurisdiction change indicator: '{signal}'")
            break

    return bool(reasons), reasons


# ---------------------------------------------------------------------------
# COMBINED SCORER
# ---------------------------------------------------------------------------

def score_article(article: dict, kyc: dict, use_embeddings: bool) -> dict:
    text = article.get("clean_text", "")
    title = article.get("title", "")
    content_lower = (title + " " + text).lower()

    # --- Component 1: keyword match ---
    kw_score = 0.0
    primary_signal = "NEGATIVE_SENTIMENT"
    matched_keywords = []
    for signal_type, base_score, keywords in RISK_LEXICON:
        hits = [kw for kw in keywords if kw in content_lower]
        if hits:
            matched_keywords.extend(hits)
            if kw_score == 0.0:
                primary_signal = signal_type
            kw_score = min(1.0, kw_score + base_score * (0.4 if kw_score > 0 else 1.0))

    # --- Component 2: entity fuzzy match ---
    fuzzy_score = entity_fuzzy_score(article, kyc)

    # --- Component 4: embedding cosine drift ---
    drift_score = embedding_drift_score(text, kyc["kyc_baseline"]["expected_business_model"], use_embeddings)

    # --- Component 5: rule-based delta ---
    delta_detected, delta_reasons = rule_based_delta(text, title, kyc)
    delta_boost = 0.20 if delta_detected else 0.0

    # --- Combined score (weighted) ---
    # Keyword is primary signal; embeddings and rules add nuance
    combined = (
        kw_score       * 0.45 +
        fuzzy_score    * 0.15 +
        drift_score    * 0.20 +
        delta_boost    * 0.20
    )
    combined = round(min(1.0, combined), 4)

    return {
        "risk_score": combined,
        "signal_type": primary_signal,
        "category": source_category(article.get("source_feed", "")),
        "delta_flag": delta_detected,
        "delta_reasons": delta_reasons,
        "matched_keywords": list(set(matched_keywords))[:10],
        "entity_fuzzy_score": fuzzy_score,
        "embedding_drift_score": drift_score,
        "keyword_score": round(kw_score, 4),
        "escalate_to_stage2": combined >= ESCALATION_THRESHOLD,
    }


# ---------------------------------------------------------------------------
# MAIN
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--company-id", required=True, help="e.g. CUST-002")
    parser.add_argument("--no-embeddings", action="store_true", help="Skip sentence-transformer step (faster)")
    args = parser.parse_args()
    use_embeddings = not args.no_embeddings

    kyc = load_kyc(args.company_id)
    if not kyc:
        print(f"Company {args.company_id} not found in KYC database.")
        return

    articles = load_articles()
    print(f"Loaded {len(articles)} articles for {kyc['legal_name']} ({args.company_id})")

    # --- Component 3: sanctions lookup (once per company, not per article) ---
    print("Checking OpenSanctions ...")
    t0 = time.time()
    is_sanctioned, sanction_matches = sanctions_lookup(kyc["legal_name"], kyc.get("key_personnel", {}))
    sanctions_ms = int((time.time() - t0) * 1000)
    if is_sanctioned:
        print(f"  ⚠  SANCTIONS HIT: {sanction_matches}")
    else:
        print(f"  ✓  No sanctions match ({sanctions_ms}ms)")

    if use_embeddings:
        get_embedding_model()  # load once before loop

    results = []
    escalated = 0
    total_cost = 0.0

    for article in articles:
        scored = score_article(article, kyc, use_embeddings)

        # Sanctions hit overrides everything
        if is_sanctioned:
            scored["risk_score"] = max(scored["risk_score"], 0.90)
            scored["signal_type"] = "SANCTIONS_HIT"
            scored["escalate_to_stage2"] = True
            scored["sanctions_matches"] = sanction_matches

        if scored["escalate_to_stage2"]:
            escalated += 1

        entry = {
            # identity
            "company_id": args.company_id,
            "legal_name": kyc["legal_name"],
            # article
            "title": article["title"],
            "url": article["url"],
            "published_at": article["published_at"],
            "summary": article.get("summary", ""),
            "source_feed": article.get("source_feed", ""),
            # scoring
            **scored,
            # cost tracking
            "stage": 1,
            "cost_usd": 0.0,
            "scored_at": datetime.now(timezone.utc).isoformat(),
        }
        results.append(entry)
        write_audit(entry)  # always log, regardless of score

    results.sort(key=lambda x: (not x["escalate_to_stage2"], -x["risk_score"]))

    output = {
        "company_id": args.company_id,
        "legal_name": kyc["legal_name"],
        "kyc_baseline": kyc["kyc_baseline"],
        "sanctions_hit": is_sanctioned,
        "sanctions_matches": sanction_matches,
        "total_articles": len(results),
        "escalated_to_stage2": escalated,
        "stage1_cost_usd": 0.0,
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "articles": results,
    }

    with OUTPUT_FILE.open("w") as f:
        json.dump(output, f, indent=2)

    print(f"\n{'─'*60}")
    print(f"Company:          {kyc['legal_name']} ({args.company_id})")
    print(f"Sanctions hit:    {'YES ⚠' if is_sanctioned else 'No'}")
    print(f"Articles scored:  {len(results)}")
    print(f"→ Stage 2:        {escalated} escalated")
    print(f"Stage 1 cost:     $0.00")
    print(f"Output:           {OUTPUT_FILE.name}")
    print(f"Audit log:        {AUDIT_LOG.name}")

    top = [x for x in results if x["escalate_to_stage2"]][:5]
    if top:
        print(f"\nTop escalated signals:")
        for r in top:
            delta = " + DELTA" if r["delta_flag"] else ""
            print(f"  [{r['risk_score']:.2f}] {r['signal_type']:<25} {r['title'][:65]}{delta}")


if __name__ == "__main__":
    main()
